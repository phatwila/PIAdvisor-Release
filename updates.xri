<?xml version="1.0" encoding="UTF-8"?>
<xri version="1.0">
   <!-- PIAdvisor PixInsight Update Repository -->
   <description>
      <p>PIAdvisor update feed for PixInsight.</p>
      <p>Status: Public package v1.1.0 published on 2026-03-12 17:47:04 UTC.</p>
      <p>Image-based chat is more natural, more reliable, and backed by stronger context handling.</p>
   </description>
   <platform os="windows" arch="x64" version="1.8.9:1.9.99">
      <package fileName="packages/PIAdvisor-windows-x64-1.1.0-20260312174704.zip" sha1="25b1f8ef9077e089a550dea4b3e1ce7712b43ec2" releaseDate="20260312174704" type="module">
         <title>PIAdvisor Module v1.1.0</title>
         <remove>bin/PIAdvisor-pxm.dll
bin/PIAdvisor-pxm.xsgn
doc/tools/PIAdvisor/PIAdvisor.html</remove>
         <description>
            <p>Image-based chat is more natural, more reliable, and backed by stronger context handling.</p>
            <p>Highlights:</p>
            <p>- Image attachments now behave like part of the conversation, including draft removal before send and reopen-and-retry from earlier turns.</p>
            <p>- PIAdvisor now gives priority to the newest attached image, while older images stay available as supporting context.</p>
            <p>- PIAdvisor now builds cleaner, more consistent context from your image, workspace, and processing history, which improves response quality.</p>
            <p>- Casual image-sharing turns feel more natural, while explicit requests for review or next steps still get full structured guidance.</p>
            <p>- Default system prompt updates are now safer: untouched defaults can upgrade on release, while custom prompts are preserved.</p>
         </description>
      </package>
   </platform>
